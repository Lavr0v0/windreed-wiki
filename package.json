{
  "name": "the-windreed-wayfarers-archive",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern public/characters/shared/lenis.min.js",
    "typecheck": "tsc --noEmit --pretty false",
    "fonts:subset": "node scripts/build-public-font-subset.mjs",
    "test:editor-local": "node scripts/smoke-editor-local.mjs",
    "audit:public-local": "node scripts/audit-public-local.mjs",
    "content:status": "node scripts/content-sync.mjs status",
    "content:push": "node scripts/content-sync.mjs push",
    "content:pull": "node scripts/content-sync.mjs pull",
    "content:export-online": "node --env-file=.env.cloudflare scripts/export-online-sync.mjs",
    "content:import-drafts": "node --env-file=.env.cloudflare scripts/import-online-drafts.mjs --confirm",
    "test:content-sync": "node --test tests/content-sync.test.mjs",
    "editor:seed:export": "node scripts/export-editor-seed.mjs",
    "db:generate": "drizzle-kit generate",
    "db:local": "wrangler d1 migrations apply DB --local --config wrangler.local.jsonc",
    "cloudflare:prepare": "node --env-file=.env.cloudflare scripts/prepare-cloudflare-deploy.mjs",
    "cloudflare:migrate": "wrangler d1 migrations apply DB --remote --config dist/server/wrangler.deploy.json",
    "cloudflare:deploy": "npm run build && npm run cloudflare:prepare && npm run cloudflare:migrate && wrangler deploy --config dist/server/wrangler.deploy.json"
  },
  "dependencies": {
    "@fontsource-variable/cinzel": "^5.2.8",
    "@fontsource-variable/noto-serif-sc": "5.2.10",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extensions": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "drizzle-orm": "0.45.2",
    "lenis": "1.3.25",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260515.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "type": "module"
}
